# Server
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000,https://lazarus.nabster.dev
TRUST_PROXY=false

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=

# Session JWT (API Authorization header only)
JWT_SECRET=
JWT_TTL_SECONDS=604800
INVITE_TTL_SECONDS=900

# API abuse protection (IP + route)
RL_AUTH_NEW_PER_MINUTE=6
RL_AUTH_NEW_PER_DAY=120
RL_UPLOAD_PER_MINUTE=6
RL_UPLOAD_PER_DAY=80
RL_UPLOAD_IP_MAX_MB_PER_DAY=300
RL_INVITE_ACCEPT_PER_MINUTE=12
RL_INVITE_ACCEPT_PER_DAY=180

# Limites (free tier friendly)
MAX_FILE_MB=10
MAX_UPLOADS_PER_DAY=15
MAX_MB_PER_DAY=200
